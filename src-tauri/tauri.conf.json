{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Compact Translator",
  "version": "0.1.0",
  "identifier": "com.personal.compacttranslator",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Compact Translator",
        "width": 1100,
        "height": 760,
        "minWidth": 900,
        "minHeight": 620,
        "center": true,
        "transparent": false,
        "decorations": false,
        "alwaysOnTop": false,
        "resizable": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' ipc://localhost wss: https:; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  }
}
